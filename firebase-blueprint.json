{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "settings": {
          "type": "object",
          "properties": {
            "defaultCurrency": { "type": "string", "enum": ["SDG", "EGP", "SAR", "USD", "EUR"] },
            "language": { "type": "string", "enum": ["ar", "en"] },
            "theme": { "type": "string", "enum": ["light", "dark"] }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Account": {
      "title": "Account",
      "description": "Financial accounts like Bank or Wallet",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "currency": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "balance", "currency", "userId"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transactions (Income, Expense, Transfer)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "accountId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense", "transfer"] },
        "status": { "type": "string", "enum": ["completed", "pending", "cancelled"] },
        "personName": { "type": "string" },
        "description": { "type": "string" },
        "transactionNumber": { "type": "string" },
        "category": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "imageUrls": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "currency", "type", "status", "timestamp"]
    },
    "Category": {
      "title": "Category",
      "description": "Transaction categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string" }
      },
      "required": ["name", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User data and settings"
    },
    "/accounts/{accountId}": {
      "schema": "Account",
      "description": "User's financial accounts"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Income, expense, and transfer records"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "User defined categories"
    }
  }
}
